# Finnhub API Key (get from https://finnhub.io/register)
FINNHUB_API_KEY=your_finnhub_api_key_here

# PostgreSQL / TimescaleDB
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=financial_terminal
POSTGRES_USER=ftuser
POSTGRES_PASSWORD=ftpassword

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Go Backend Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# WebSocket
WS_PORT=8081
# Batch price updates every N milliseconds (reduces Finnhub WS API calls)
WS_BATCH_INTERVAL=3000
# Maximum concurrent WebSocket clients (single-user app)
WS_MAX_CLIENTS=1

# Cache TTLs (seconds)
CACHE_QUOTE_TTL=1800
CACHE_CANDLE_INTRADAY_TTL=300
CACHE_CANDLE_DAILY_TTL=7200
CACHE_NEWS_TTL=1800

# API Rate Limiting
# Finnhub free tier: 60 calls/min realtime, 1 call/sec for others
RATE_LIMIT_REALTIME=60
RATE_LIMIT_OTHERS=60

# Log level: debug, info, warn, error
LOG_LEVEL=info
