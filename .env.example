# Finnhub API Key (get from https://finnhub.io/register)
FINNHUB_API_KEY=your_finnhub_api_key_here

# PostgreSQL / TimescaleDB
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=financial_terminal
POSTGRES_USER=ftuser
POSTGRES_PASSWORD=ftpassword

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Go Backend Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# WebSocket
WS_PORT=8081

# Log level: debug, info, warn, error
LOG_LEVEL=info
